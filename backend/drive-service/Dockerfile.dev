FROM node:22-alpine

RUN apk add --no-cache make gcc g++ python3

ARG PORT
ARG GOOGLE_APP_CLIENT_ID
ARG GOOGLE_APP_PROJECT_ID
ARG GOOGLE_APP_AUTH_URI
ARG GOOGLE_APP_TOKEN_URI
ARG GOOGLE_APP_AUTH_PROVIDER_X509_CERT_URL
ARG GOOGLE_APP_CLIENT_SECRET
ARG GOOGLE_APP_REDIRECT_URI

ENV PORT=${PORT}
ENV GOOGLE_APP_CLIENT_ID=${GOOGLE_APP_CLIENT_ID}
ENV GOOGLE_APP_PROJECT_ID=${GOOGLE_APP_PROJECT_ID}
ENV GOOGLE_APP_AUTH_URI=${GOOGLE_APP_AUTH_URI}
ENV GOOGLE_APP_TOKEN_URI=${GOOGLE_APP_TOKEN_URI}
ENV GOOGLE_APP_AUTH_PROVIDER_X509_CERT_URL=${GOOGLE_APP_AUTH_PROVIDER_X509_CERT_URL}
ENV GOOGLE_APP_CLIENT_SECRET=${GOOGLE_APP_CLIENT_SECRET}
ENV GOOGLE_APP_REDIRECT_URI=${GOOGLE_APP_REDIRECT_URI}
ENV CI=true

RUN npm install -g pnpm

WORKDIR /app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN pnpm config set store-dir /pnpm/store

COPY package.json pnpm-lock.yaml .npmrc ./

RUN pnpm install --ignore-scripts
RUN pnpm approve-builds @nestjs/core unrs-resolver protobufjs bcrypt
RUN pnpm install

COPY . .

EXPOSE $PORT

CMD ["pnpm", "run", "start:dev"]

